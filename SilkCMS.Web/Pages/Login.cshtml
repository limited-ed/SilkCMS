@page
@model LoginModel

@{
  ViewData["Title"] = "Log in";

}

@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />
  <title>Sign in - Tabler - Premium and Open Source dashboard template with responsive and high quality UI.</title>
  <!-- CSS files -->
  <link href="/private/css/tabler.min.css?1684106062" rel="stylesheet" />
  <link href="/private/css/tabler-flags.min.css?1684106062" rel="stylesheet" />
  <link href="/private/css/tabler-payments.min.css?1684106062" rel="stylesheet" />
  <link href="/private/css/tabler-vendors.min.css?1684106062" rel="stylesheet" />
  <link href="/private/css/demo.min.css?1684106062" rel="stylesheet" />
</head>

<body class=" d-flex flex-column">
  <script src="/private/js/demo-theme.min.js?1684106062"></script>
  <div class="page page-center">
    <div class="container container-tight py-4">
      <div class="text-center mb-4">
        <a href="." class="navbar-brand navbar-brand-autodark"><img src="./static/logo.svg" height="36" alt=""></a>
      </div>
      <div class="card card-md">
        <div class="card-body">
          <h2 class="h2 text-center mb-4">@Localizer["Login"]</h2>
          <form id="account" method="post">
            <div class="mb-3">
              <label class="form-label">@Localizer["Email address"]</label>
              <input type="email" class="form-control" asp-for="Input.Email" autocomplete="username"
                aria-required="true" placeholder="your@email.com">
            </div>
            <div class="mb-2">
              <label class="form-label">
                @Localizer["Password"]
                <span class="form-label-description">
                  <a href="./forgot-password.html">@Localizer["I forgot password"]</a>
                </span>
              </label>
              <div class="input-group input-group-flat">
                <input type="password" class="form-control" placeholder="@Localizer["Your password"]"
                  asp-for="Input.Password" class="password" autocomplete="current-password" aria-required="true">
                <span class="input-group-text">
                  <a href="#" class="link-secondary" title="@Localizer["Show password"]"
                    data-bs-toggle="tooltip"><!-- Download SVG icon from http://tabler-icons.io/i/eye -->
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24"
                      stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                      <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                      <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6" />
                    </svg>
                  </a>
                </span>
              </div>
            </div>
            <div class="mb-2">
              <label class="form-check">
                <input type="checkbox" class="form-check-input" asp-for="Input.RememberMe" />
                <span class="form-check-label">@Localizer["Remember me on this device"]</span>
              </label>
            </div>
            <div class="mb-2">
              @{
                foreach (var error in ViewData.ModelState.Values.SelectMany(modelState => modelState.Errors))  
                {
                  <div>@error.ErrorMessage</div>
                }
              }
            </div>
            <div class="form-footer">
              <button type="submit" class="btn btn-primary w-100">@Localizer["Sign in"]</button>
            </div>
          </form>
        </div>
        <div class="hr-text">@Localizer["Sign in with"]</div>
        <div class="card-body">
          <div class="row">
            <div class="col">
              @foreach (var provider in Model.ExternalLogins!)
              {
                <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name"
                  title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
              }
            </div>
          </div>
        </div>
      </div>
      <div class="text-center text-muted mt-3">
        @Localizer["Don't have account yet?"] <a href="./sign-up.html" tabindex="-1">@Localizer["Sign up"]</a>
      </div>
    </div>
  </div>
  <!-- Libs JS -->
  <!-- Tabler Core -->
  <script src="/private/js/tabler.min.js?1684106062" defer></script>
</body>

</html>
