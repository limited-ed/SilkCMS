<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <Company>SilkCMS</Company>
    <Copyright>Yaros Roman</Copyright>
    <Description>SilkCMS Administrator</Description>
    <Product>SilkCMS Administrator</Product>
    <AssemblyTitle>Blog</AssemblyTitle>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SilkCMS.Abstractions\SilkCMS.Abstractions.csproj" />
    <ProjectReference Include="..\SilkCMS.Data\SilkCMS.Data.csproj" />
    <ProjectReference Include="..\SilkCMS.Core\SilkCMS.Core.csproj" />
  </ItemGroup>

  <Target Name="CopyToProject" AfterTargets="AfterBuild">
    <Copy SourceFiles="$(TargetDir)$(MSBuildProjectName).dll" DestinationFolder="$(TargetDir)\..\..\..\..\SilkCMS.Web\Modules\$(MSBuildProjectName)" SkipUnchangedFiles="true" Retries="0" />
    <Message Text="Copied @(MainAssembly) to $(DEVPATH)" />
  </Target>

  <ItemGroup>
    <EmbeddedResource Include="wwwroot\**\*" />
  </ItemGroup>

  <ItemGroup>
    <Content Remove="Views\Shared\Components\MenuItemComponent\DropdownItemDropdown.cshtml" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Views\Shared\Components\MenuItemComponent\DropdownItemDropdown.cshtml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" Version="8.0.3" />
  </ItemGroup>

</Project>
